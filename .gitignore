# ============================================
# .gitignore for Feedback Automation Project
# ============================================

# ============================================
# CREDENTIALS & SECRETS - NEVER COMMIT
# ============================================
.env
.env.local
.env.*.local
*.env

# API Keys
credentials.json
secrets.json
*-credentials.json
config-local.js
config.local.js

# Token files
*.token
*.key
*.pem

# ============================================
# LOCAL CONFIGURATION
# ============================================
config/local.json
.config/

# ============================================
# NGROK
# ============================================
ngrok.exe
ngrok
ngrok-*.zip
*.ngrok.io

# ============================================
# N8N LOCAL DATA
# ============================================
.n8n/
n8n-data/

# ============================================
# OS GENERATED FILES
# ============================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# ============================================
# IDE & EDITORS
# ============================================
# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================
# LOGS & DEBUG
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug/

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup
tmp/
temp/

# ============================================
# BUILD & DEPENDENCIES
# ============================================
node_modules/
dist/
build/
*.min.js
*.min.css

# ============================================
# BACKUP FILES (keep in separate backup)
# ============================================
*-backup.*
*.old
backups/

# ============================================
# SCREENSHOTS WITH SENSITIVE DATA
# ============================================
# Add specific screenshots to .gitignore if they contain sensitive info
# docs/screenshots/private/

# ============================================
# ERROR SCREENSHOTS (may contain sensitive info)
# ============================================
error*.jpg
error*.png
debug*.jpg
debug*.png
